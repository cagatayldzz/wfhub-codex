{
  "$schema": "https://turbo.build/schema.v2.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["!dist/**"]
    },
    "oxfmt": {
      "cache": false
    },
    "oxlint": {
      "cache": true
    },
    "test": {
      "cache": true
    },
    "typecheck": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
