{
  "name": "wfhub-codex",
  "version": "0.0.1",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && bun run start",
    "start": "bun dist/main.js",
    "build": "bun run clean && tsc && bun dist/main.js",
    "clean": "rimraf dist data",
    "update": "bun update -i",
    "commit": "git add -A && git commit --no-verify --message \"chore: update\"",
    "format": "turbo oxfmt oxlint",
    "oxfmt": "oxfmt --write",
    "oxlint": "oxlint --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@wfcd/items": "^1.1273.17"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "npm-check-updates": "^20.0.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "bun@1.3.12"
}
